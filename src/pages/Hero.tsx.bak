import React, { useEffect, useRef, useState } from "react";
import gsap from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
import { ArrowRight, Cpu, Globe, Code, Database, Zap, Layers } from "lucide-react";
import { Button } from "@/components/ui/button";

gsap.registerPlugin(ScrollTrigger);

/* ─── Decorative SVG Components ─── */
const JapanesePattern: React.FC<{ className?: string }> = ({ className }) => (
  <svg className={className} width="100" height="100" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 50C0 22.3858 22.3858 0 50 0C77.6142 0 100 22.3858 100 50" stroke="currentColor" strokeWidth="1" strokeOpacity="0.2"/>
    <path d="M0 100C0 72.3858 22.3858 50 50 50C77.6142 50 100 72.3858 100 100" stroke="currentColor" strokeWidth="1" strokeOpacity="0.2"/>
  </svg>
);

const KamonIcon: React.FC<{ className?: string }> = ({ className }) => (
  <svg className={className} viewBox="0 0 100 100" fill="none" stroke="currentColor" strokeWidth="2">
    <circle cx="50" cy="50" r="45" />
    <path d="M50 5 L50 95 M5 50 L95 50" strokeOpacity="0.5"/>
    <rect x="25" y="25" width="50" height="50" transform="rotate(45 50 50)" strokeOpacity="0.5"/>
  </svg>
);

const VerticalText: React.FC<{ text: string; className?: string }> = ({ text, className }) => (
  <div className={`flex flex-col items-center justify-center font-serif leading-none tracking-widest ${className}`} style={{ writingMode: "vertical-rl", textOrientation: "upright" }}>
    {text.split("").map((char, i) => (
      <span key={i} className="my-1 block">{char}</span>
    ))}
  </div>
);

const LaravelLogo: React.FC<{ className?: string }> = ({ className }) => (
  <svg className={className} viewBox="0 0 50 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M49.5 13.5L27.5 0L5.5 13.5V40.5L27.5 54L49.5 40.5V13.5Z" fill="currentColor" fillOpacity="0.1" stroke="currentColor" strokeWidth="1"/>
    <path d="M27.5 15L15 22.5V37.5L27.5 45L40 37.5V22.5L27.5 15Z" fill="currentColor" fillOpacity="0.2"/>
  </svg>
);

const GlowingOrb: React.FC<{ className?: string; color?: string }> = ({ className, color = "primary" }) => {
  const ref = useRef<HTMLDivElement>(null);
  useEffect(() => {
    gsap.to(ref.current, { scale: 1.2, opacity: 0.6, duration: 2, repeat: -1, yoyo: true, ease: "sine.inOut" });
  }, []);
  return (
    <div ref={ref} className={`absolute rounded-full blur-3xl ${className}`} style={{ background: `radial-gradient(circle, var(--${color}) 0%, transparent 70%)` }} />
  );
};

const DataStream: React.FC = () => {
  const containerRef = useRef<HTMLDivElement>(null);
  useEffect(() => {
    const ctx = gsap.context(() => {
      const lines = containerRef.current?.querySelectorAll(".data-line");
      if (lines && lines.length > 0) {
        gsap.to(lines, { y: "100%", duration: 20, repeat: -1, ease: "none", stagger: { amount: 10, from: "random" } });
      }
    }, containerRef);
    return () => ctx.revert();
  }, []);
  return (
    <div ref={containerRef} className="absolute right-0 top-0 h-full w-40 overflow-hidden opacity-10 pointer-events-none hidden lg:block">
      {Array.from({ length: 12 }).map((_, i) => (
        <div key={i} className="data-line absolute top-[-100%] left-0 w-full text-[9px] font-mono leading-none text-primary whitespace-nowrap" style={{ left: `${i * 15}%` }}>
          {Array.from({ length: 25 }).map(() => Math.floor(Math.random() * 16).toString(16)).join(" ")}
        </div>
      ))}
    </div>
  );
};

/* ─── Aperture Iris Cinematic Intro Overlay ─── */
const ApertureOverlay: React.FC<{ onComplete?: () => void }> = ({ onComplete }) => {
  const overlayRef = useRef<HTMLDivElement>(null);
  const pattern1Ref = useRef<HTMLDivElement>(null);
  const pattern2Ref = useRef<HTMLDivElement>(null);
  const kamonRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const tl = gsap.timeline({
      onComplete: () => {
        if (overlayRef.current) overlayRef.current.style.pointerEvents = "none";
        onComplete?.();
      }
    });

    tl.set([pattern1Ref.current, pattern2Ref.current, kamonRef.current], {
      scale: 0.2, opacity: 0, rotation: 0
    })
    .to([pattern1Ref.current, pattern2Ref.current, kamonRef.current], {
      scale: 1, opacity: 1, duration: 1.2, ease: "expo.out", stagger: 0.1
    })
    .to(pattern1Ref.current, { rotation: 180, duration: 2.5, ease: "power2.inOut" }, "<")
    .to(pattern2Ref.current, { rotation: -180, duration: 2.5, ease: "power2.inOut" }, "<")
    .to(kamonRef.current, { rotation: 90, scale: 3, duration: 2.5, ease: "power2.inOut" }, "<")
    .to([pattern1Ref.current, pattern2Ref.current, kamonRef.current], {
      scale: 8, opacity: 0, duration: 1.2, ease: "power4.in", stagger: 0.05
    }, "-=0.5")
    .to(overlayRef.current, {
      opacity: 0, duration: 0.8, ease: "power2.out"
    }, "-=0.6");

    return () => { tl.kill(); };
  }, [onComplete]);

  return (
    <div ref={overlayRef} className="fixed inset-0 z-[100] bg-background flex items-center justify-center pointer-events-auto">
      <div ref={pattern1Ref} className="absolute opacity-0">
        <JapanesePattern className="h-96 w-96 text-primary opacity-40" />
      </div>
      <div ref={pattern2Ref} className="absolute opacity-0">
        <JapanesePattern className="h-64 w-64 text-secondary opacity-30" />
      </div>
      <div ref={kamonRef} className="absolute opacity-0">
        <KamonIcon className="h-32 w-32 text-primary opacity-60" />
      </div>
      <div className="absolute bottom-12 font-mono text-[10px] uppercase tracking-[0.3em] text-muted-foreground/50 animate-pulse">
        Initializing Artisan Environment
      </div>
    </div>
  );
};

/* ─── Main Hero ─── */
const Hero: React.FC = () => {
  const containerRef = useRef<HTMLDivElement>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const masterContentRef = useRef<HTMLDivElement>(null);
  const terminalWrapperRef = useRef<HTMLDivElement>(null);
  const activeTabLineRef = useRef<HTMLDivElement>(null);

  const [activeTab, setActiveTab] = useState<string>("starter-kit");

  const tabs: CodeTab[] = [
    {
      id: "starter-kit",
      name: "KoamiStarterKit.sh",
      icon: <Terminal className="h-3.5 w-3.5" />,
      code: `$ composer create-project koamishin/starter-kit my-artisan-app

[1/3] Spinning up modern web structure... Done.
[2/3] Integrating Vue 3 & Inertia.js SPAs... Done.
[3/3] Injecting Tailwind CSS v4... Done.

✔ Auth, User management & tooling successfully compiled.
✔ Ready to build premium enterprise systems with elegance.

$ cd my-artisan-app && php artisan serve`
    },
    {
      id: "scholarships",
      name: "KoaScholarship.php",
      icon: <Code className="h-3.5 w-3.5" />,
      code: `<?php

namespace Koamishin\\Scholarships;

class OpenSourceArtisanGrant extends Scholarship
{
    public function authorize(Developer $artisan): bool
    {
        // Empowering the developer community
        return $artisan->hasPassion() 
            && $artisan->buildsOpenSource();
    }

    public function award(Developer $artisan): Grant
    {
        return Grant::create([
            'amount' => 5000,
            'purpose' => 'Lowering barriers to innovation',
            'support' => 'Meticulous Laravel solutions'
        ]);
    }
}`
    },
    {
      id: "koamishin-ethos",
      name: "KoamishinEthos.json",
      icon: <Layers className="h-3.5 w-3.5" />,
      code: `{
  "name": "小網新 (Koamishin)",
  "etymology": {
    "koami": "Small Net / Intricate Mesh of developers",
    "shin": "Renewal / Continuous digital innovation"
  },
  "focus": [
    "High-quality Laravel applications",
    "Tailwind CSS v4 & modern SPA architectures",
    "Empowering global open-source ecosystems"
  ],
  "philosophy": "Where code is crafted with artisan pride."
}`
    }
  ];

  // 1. Fluid Canvas Particle Network (The Thread Loom)
  // Transitioning from mesh into a guided vertical trail as user scrolls into About section
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    let animationId: number;
    let particles: Particle[] = [];
    const particleCount = 40;
    let scrollProgress = 0;
    let mouse = { x: -1000, y: -1000 };

    const resize = () => {
      canvas.width = canvas.parentElement?.clientWidth || window.innerWidth;
      canvas.height = canvas.parentElement?.clientHeight || window.innerHeight;
      initParticles();
    };

    const initParticles = () => {
      particles = [];
      for (let i = 0; i < particleCount; i++) {
        const x = Math.random() * canvas.width;
        const y = Math.random() * canvas.height;
        particles.push({
          x,
          y,
          vx: (Math.random() - 0.5) * 0.2,
          vy: (Math.random() - 0.5) * 0.2,
          radius: Math.random() * 1.5 + 1.0,
          baseX: x,
          baseY: y
        });
      }
    };

    const handleMouseMove = (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    };

    const handleMouseLeave = () => {
      mouse.x = -1000;
      mouse.y = -1000;
    };

    const draw = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const isDark = document.documentElement.classList.contains("dark");
      
      const nodeColor = isDark ? "rgba(239, 68, 68, 0.45)" : "rgba(220, 38, 38, 0.35)";
      const lineColor = isDark ? "rgba(239, 68, 68, 0.08)" : "rgba(220, 38, 38, 0.06)";
      const trailColor = isDark ? "rgba(239, 68, 68, 0.2)" : "rgba(220, 38, 38, 0.15)";

      // Ambient background grid blueprint
      ctx.strokeStyle = isDark ? "rgba(255, 255, 255, 0.01)" : "rgba(0, 0, 0, 0.01)";
      ctx.lineWidth = 1;
      const gridSize = 45;
      for (let x = 0; x < canvas.width; x += gridSize) {
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x, canvas.height);
        ctx.stroke();
      }
      for (let y = 0; y < canvas.height; y += gridSize) {
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(canvas.width, y);
        ctx.stroke();
      }

      // Draw continuous guided waterfall line when scrolling down to create a seamless link
      if (scrollProgress > 0.05) {
        ctx.strokeStyle = trailColor;
        ctx.lineWidth = 1;
        ctx.setLineDash([4, 12]);
        ctx.beginPath();
        ctx.moveTo(canvas.width / 2, 0);
        ctx.lineTo(canvas.width / 2, canvas.height);
        ctx.stroke();
        ctx.setLineDash([]);
      }

      particles.forEach((p, idx) => {
        // Morph logic: As user scrolls, draw particles towards a vertical waterfall trail in the center
        if (scrollProgress > 0.1) {
          const targetX = canvas.width / 2 + Math.sin(p.baseY * 0.01 + idx) * 30;
          const targetY = p.y + (0.5 * scrollProgress); // Slow slide downward

          p.x += (targetX - p.x) * 0.06;
          p.y += (targetY - p.y) * 0.06;
        } else {
          // Normal floating orbit behavior
          p.x += p.vx;
          p.y += p.vy;
        }

        // Wrap boundaries
        if (p.x < 0) p.x = canvas.width;
        if (p.x > canvas.width) p.x = 0;
        if (p.y < 0) p.y = canvas.height;
        if (p.y > canvas.height) p.y = 0;

        // Interactive mouse push
        if (mouse.x > 0 && mouse.y > 0) {
          const dx = mouse.x - p.x;
          const dy = mouse.y - p.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 180) {
            p.x += dx * -0.005;
            p.y += dy * -0.005;
          }
        }

        ctx.fillStyle = nodeColor;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx.fill();
      });

      // Connection lines
      ctx.lineWidth = 0.7;
      const maxDistance = 150 * (1 - scrollProgress * 0.4); // Dissolve network connection range on scroll to focus on the trail
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < maxDistance) {
            const alpha = (1 - dist / maxDistance) * 0.6;
            ctx.strokeStyle = lineColor.replace(/[\d.]+\)$/, `${alpha})`);
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }

      animationId = requestAnimationFrame(draw);
    };

    const scrollTrigger = ScrollTrigger.create({
      trigger: containerRef.current,
      start: "top top",
      end: "bottom top",
      scrub: true,
      onUpdate: (self) => {
        scrollProgress = self.progress;
      }
    });

    window.addEventListener("resize", resize);
    window.addEventListener("mousemove", handleMouseMove);
    canvas.addEventListener("mouseleave", handleMouseLeave);
    
    resize();
    draw();

    return () => {
      window.removeEventListener("resize", resize);
      window.removeEventListener("mousemove", handleMouseMove);
      canvas.removeEventListener("mouseleave", handleMouseLeave);
      scrollTrigger.kill();
      cancelAnimationFrame(animationId);
    };
  }, []);

  // 2. Unfolding Sequence and Seamless Scroll Connection (Gsap ScrollTrigger)
  useEffect(() => {
    const ctx = gsap.context(() => {
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

      // Clean cinematic reveal
      tl.fromTo(".reveal-badge",
        { opacity: 0, y: -25, scale: 0.95 },
        { opacity: 1, y: 0, scale: 1, duration: 1.1 }
      )
      .fromTo(".reveal-title",
        { opacity: 0, y: 40, filter: "blur(8px)" },
        { opacity: 1, y: 0, filter: "blur(0px)", duration: 1.3, ease: "power4.out" },
        "-=0.9"
      )
      .fromTo(".reveal-desc",
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 1 },
        "-=1.0"
      )
      .fromTo(".reveal-cta",
        { opacity: 0, y: 15 },
        { opacity: 1, y: 0, duration: 0.8 },
        "-=0.9"
      )
      .fromTo(terminalWrapperRef.current,
        { opacity: 0, y: 50, scale: 0.97, filter: "blur(12px)" },
        { opacity: 1, y: 0, scale: 1, filter: "blur(0px)", duration: 1.4, ease: "power4.out" },
        "-=1.1"
      )
      .fromTo(".scroll-guide-indicator",
        { opacity: 0, y: -10 },
        { opacity: 0.6, y: 0, repeat: -1, yoyo: true, duration: 1.5, ease: "sine.inOut" },
        "-=0.5"
      );

      // Seamless scroll interaction: Unfolds, aligns, and slides Hero cleanly under the About section header
      gsap.to(masterContentRef.current, {
        y: -100,
        scale: 0.96,
        opacity: 0.15,
        filter: "blur(10px)",
        scrollTrigger: {
          trigger: containerRef.current,
          start: "top top",
          end: "bottom top",
          scrub: 1.2
        }
      });

      // Terminal scrolls slightly faster for subtle parallex depth
      gsap.to(terminalWrapperRef.current, {
        y: -40,
        scale: 0.98,
        opacity: 0.1,
        filter: "blur(8px)",
        scrollTrigger: {
          trigger: containerRef.current,
          start: "top top",
          end: "bottom top",
          scrub: 0.8
        }
      });
      
    }, containerRef);

    return () => ctx.revert();
  }, []);

  useEffect(() => {
    const activeBtn = document.getElementById(`tab-btn-${activeTab}`);
    if (activeBtn && activeTabLineRef.current) {
      activeTabLineRef.current.style.width = `${activeBtn.offsetWidth}px`;
      activeTabLineRef.current.style.left = `${activeBtn.offsetLeft}px`;
    }
  }, [activeTab]);

  return (
    <section
      ref={containerRef}
      className="relative min-h-[92vh] w-full bg-background flex flex-col justify-center border-b border-border/40 select-none overflow-hidden"
    >
      {/* Background Loom Grid & Morphing Particles */}
      <div className="absolute inset-0 -z-20 overflow-hidden">
        <canvas ref={canvasRef} className="absolute inset-0 h-full w-full opacity-65" />
      </div>

      {/* Elegant, balanced backdrop studio lighting */}
      <div className="absolute top-[10%] left-1/2 -translate-x-1/2 -z-10 h-[500px] w-[500px] rounded-full bg-primary/5 blur-[120px] pointer-events-none" />

      {/* Main Container: Centered editorial design for maximum aesthetic synergy with the rest of the layout */}
      <div ref={masterContentRef} className="container mx-auto px-6 md:px-12 py-12 md:py-20 relative z-10 flex flex-col items-center text-center">
        
        {/* Brand Signifier Tag */}
        <div className="reveal-badge mb-6 flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 font-mono text-[10px] uppercase tracking-[0.25em] text-primary shadow-sm shadow-primary/5">
          <KamonMini className="h-4.5 w-4.5 animate-spin-slow" />
          <span>小網新</span>
          <span className="opacity-40">•</span>
          <span>Koamishin Collective</span>
        </div>

        {/* Centered Editorial Headline */}
        <h1 className="reveal-title mb-6 font-serif text-5xl font-extrabold leading-[1.1] tracking-tight text-foreground md:text-6xl lg:text-7xl max-w-4xl">
          Crafting Modern, High-End <br />
          <span className="bg-gradient-to-r from-primary via-red-500 to-rose-500 bg-clip-text text-transparent italic font-light pr-2">
            Laravel Solutions
          </span>
        </h1>

        {/* Meticulous Subtext explaining our objective */}
        <p className="reveal-desc mb-8 text-lg font-light leading-relaxed text-muted-foreground md:text-xl max-w-2xl">
          We weave intricate digital networks to build 100% open-source packages, starter kits, and professional systems. Grounded in meticulous artisanship and community dedication.
        </p>

        {/* Simple, Solid CTAs */}
        <div className="reveal-cta flex flex-wrap justify-center gap-4 mb-16 w-full sm:w-auto">
          <Button asChild size="lg" className="h-12 rounded-none px-8 bg-primary hover:bg-primary/90 text-primary-foreground font-medium text-sm shadow-lg shadow-primary/15 transition-all duration-300 hover:translate-y-[-1px]">
            <a href="#projects" className="flex items-center gap-2 group">
              Explore Our Craft 
              <ArrowRight className="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" />
            </a>
          </Button>
          <Button asChild variant="outline" size="lg" className="h-12 rounded-none px-8 border-border/80 hover:bg-muted font-medium text-sm transition-all duration-300 hover:translate-y-[-1px]">
            <a href="/docs" className="flex items-center gap-2">
              Read the Documentation
            </a>
          </Button>
        </div>

        {/* Beautiful, Compact Interactive Code Terminal */}
        <div ref={terminalWrapperRef} className="w-full max-w-2xl bg-card border border-border shadow-2xl overflow-hidden rounded-sm flex flex-col relative z-20">
          
          {/* Decorative Backing Glow */}
          <div className="absolute inset-0 bg-gradient-to-b from-primary/10 to-transparent opacity-30 pointer-events-none" />

          {/* Console Header */}
          <div className="flex items-center justify-between px-4 py-3 border-b border-border/55 bg-muted/40 relative z-10">
            <div className="flex items-center gap-1.5">
              <span className="w-2.5 h-2.5 rounded-full bg-red-500/60" />
              <span className="w-2.5 h-2.5 rounded-full bg-yellow-500/60" />
              <span className="w-2.5 h-2.5 rounded-full bg-green-500/60" />
            </div>
            <span className="text-[10px] font-mono tracking-wider text-muted-foreground/85 flex items-center gap-1.5">
              <Sparkles className="h-3 w-3 text-primary animate-pulse" />
              Interactive Console
            </span>
          </div>

          {/* Dynamic Tab Bar */}
          <div className="flex border-b border-border/40 bg-muted/25 relative z-10">
            {tabs.map((tab) => (
              <button
                key={tab.id}
                id={`tab-btn-${tab.id}`}
                onClick={() => setActiveTab(tab.id)}
                className={`flex items-center gap-2 px-5 py-2.5 font-mono text-[11px] transition-colors duration-300 relative border-r border-border/30 hover:bg-muted/15 ${
                  activeTab === tab.id ? "text-foreground bg-background font-medium" : "text-muted-foreground hover:text-foreground"
                }`}
              >
                {tab.icon}
                {tab.name}
              </button>
            ))}
            
            {/* Tab Highlighter */}
            <div
              ref={activeTabLineRef}
              className="absolute bottom-[-1px] h-[2px] bg-primary transition-all duration-300 ease-out"
              style={{ width: 0, left: 0 }}
            />
          </div>

          {/* Active Code Panel */}
          <div className="p-6 font-mono text-xs text-muted-foreground leading-relaxed text-left overflow-x-auto min-h-[220px] bg-card relative z-10">
            <pre className="whitespace-pre">
              <code className="block text-foreground/95 select-all">
                {tabs.find((t) => t.id === activeTab)?.code}
              </code>
            </pre>
          </div>

        </div>

      </div>

      {/* Seamless Floating Scroll Guide (Guides the eye straight down the Waterfall trail into About) */}
      <div className="scroll-guide-indicator absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1 cursor-pointer pointer-events-none opacity-60">
        <span className="font-mono text-[9px] uppercase tracking-[0.2em] text-muted-foreground">Scroll</span>
        <ChevronDown className="h-4 w-4 text-primary" />
      </div>

    </section>
  );
};

export default Hero;



